{
  "productName": "Blesus",
  "version": "0.1.0",
  "identifier": "com.opencursus.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Blesus",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "dragDropEnabled": false,
        "center": true,
        "focus": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; connect-src 'self' http://ipc.localhost https://api.resend.com https://api.github.com https://cdn.jsdelivr.net; img-src 'self' data: https:; font-src 'self' data:; frame-src 'self'; worker-src blob: 'self' https://cdn.jsdelivr.net; media-src blob: 'self'"
    },
    "trayIcon": null
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["libayatana-appindicator3-1 | libappindicator3-1"],
        "desktopTemplate": "linux/desktop.template"
      }
    }
  },
  "plugins": {}
}
